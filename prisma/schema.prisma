generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------
// Wymagane dla Multi-Tenancy (Firmy obsługiwane w systemie)
// ---------------------------------------------------------
model Tenant {
  id          String   @id @default(uuid())
  name        String   @unique
  nip                String?
  ksefToken          String?
  ksefAccessToken    String?
  ksefRefreshToken   String?
  ksefTokenExpiresAt DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  users              User[]
  contractors        Contractor[]
  projects           Project[]
  invoices           Invoice[]
  transactions       Transaction[]
  liabilities        Liability[]
  legacyDebts        LegacyDebt[]
  bankAccounts       BankAccount[]
  bankTransactions   BankTransactionRaw[]
  auditLogs          AuditLog[]
  retentions         Retention[]
  notifications      Notification[]
  ksefInvoices       KsefInvoice[]
  bankStaging        BankStaging[]
  bankBalanceStates  BankBalanceState[]
  ledgerEntries      LedgerEntry[]
  assets             Asset[]
  contractorBankAccounts ContractorBankAccount[]
  identityConflicts  IdentityConflictRecord[]
}

model BankBalanceState {
  id                    String   @id @default(uuid())
  tenantId              String
  tenant                Tenant   @relation(fields: [tenantId], references: [id])
  verifiedBalance       Decimal  @db.Decimal(12, 2)
  verificationTimestamp DateTime @default(now())
  source                String   // e.g., "PKO_BP_CSV"
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([tenantId])
  @@index([verificationTimestamp])
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique // e.g., OWNER, MANAGER, EMPLOYEE
  permissions Json?
  users       User[]
}

model User {
  id            String   @id @default(uuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  email         String   @unique
  passwordHash  String
  firstName     String
  lastName     String
  roleId        String
  role          Role     @relation(fields: [roleId], references: [id])
  auditLogs     AuditLog[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId])
}

// ---------------------------------------------------------
// CRM & Projekty
// ---------------------------------------------------------
model Contractor {
  id           String    @id @default(uuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id])
  nip          String?
  name         String
  address      String?
  type         String    @default("INWESTOR") // INWESTOR, DOSTAWCA, HURTOWNIA
  status       String    @default("ACTIVE")
  creditRating Int?
  bankAccounts String[]  @default([]) // Deprecated in favor of accounts (Vector 116)
  accounts     ContractorBankAccount[]
  objects      Object[]
  contacts     Contact[]
  projects     Project[]
  invoices     Invoice[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  retentions   Retention[]
  transactions Transaction[]
  assets       Asset[]

  @@index([tenantId])
  @@unique([tenantId, nip])
}

model Object {
  id           String     @id @default(uuid())
  contractorId String
  contractor   Contractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  name         String
  address      String?
  description  String?
  projects     Project[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Contact {
  id           String     @id @default(uuid())
  contractorId String
  contractor   Contractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  firstName    String
  lastName     String
  email        String?
  phone        String?
  position     String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Project {
  id              String         @id @default(uuid())
  tenantId        String
  tenant          Tenant         @relation(fields: [tenantId], references: [id])
  contractorId    String
  contractor      Contractor     @relation(fields: [contractorId], references: [id])
  objectId        String
  object          Object         @relation(fields: [objectId], references: [id])
  name            String
  type            String
  status          String         @default("PLANNED")
  budgetEstimated Decimal        @default(0) @db.Decimal(12, 2)
  budgetUsed      Decimal        @default(0) @db.Decimal(12, 2)
  stages          ProjectStage[]
  invoices        Invoice[]
  transactions    Transaction[]
  ledgerEntries   LedgerEntry[]
  retentions      Retention[]
  lifecycleStatus String         @default("ACTIVE")
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  estimatedCompletionDate DateTime?
  warrantyPeriodYears     Int       @default(0)
  
  retentionShortTermRate Decimal @default(0) @db.Decimal(5, 4)
  retentionLongTermRate  Decimal @default(0) @db.Decimal(5, 4)
  retentionBase          RetentionBase @default(GROSS)

  assets          Asset[]
  @@index([tenantId])
  @@index([tenantId, status])
}

enum RetentionBase {
  NET
  GROSS
}

model ProjectStage {
  id              String    @id @default(uuid())
  projectId       String
  project         Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name            String
  budgetEstimated Decimal   @default(0) @db.Decimal(12, 2)
  deadline        DateTime?
  status          String    @default("PENDING")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// ---------------------------------------------------------
// Finanse & Cash Flow
// ---------------------------------------------------------
model Invoice {
  id           String        @id @default(uuid())
  tenantId     String
  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  contractorId String
  contractor   Contractor    @relation(fields: [contractorId], references: [id])
  projectId    String?
  project      Project?      @relation(fields: [projectId], references: [id])
  type         String
  amountNet    Decimal       @db.Decimal(12, 2)
  amountGross  Decimal       @db.Decimal(12, 2)
  taxRate      Decimal       @db.Decimal(5, 4)
  issueDate    DateTime
  dueDate      DateTime
  status       String        @default("ACTIVE") // DRAFT, ACTIVE, PAID, PARTIALLY_PAID, REVERSED
  paymentStatus String       @default("UNPAID")
  paymentMethod String       @default("BANK_TRANSFER") // BANK_TRANSFER, CASH, CARD
  reconciliationStatus String @default("PENDING") // PENDING, MATCHED, GAP
  ksefId       String?
  ksefType     String?
  invoiceNumber String?
  externalId   String?
  bankTransactionId String?    @unique // Link do wyciągu bankowego (zapobiega dublowaniu)
  scanUrl      String?       // OCR: Link do skanu/zasobu zewnętrznego
  
  // Kaucje Gwarancyjne (Retention Money)
  retainedAmount       Decimal? @db.Decimal(12, 2)
  retentionReleaseDate DateTime?
  retentions           Retention[]

  payments     InvoicePayment[]
  assets       Asset[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([tenantId])
  @@index([tenantId, dueDate])
  @@index([tenantId, status])
  @@unique([ksefId])
  @@unique([contractorId, invoiceNumber])
  @@unique([tenantId, contractorId, externalId, type])
}

model LegacyDebt {
  id              String   @id @default(uuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  creditor        String   // Wierzyciel
  name            String   // Nazwa długu (np. Kredyt obrotowy 2024)
  totalAmount     Decimal  @db.Decimal(12, 2)
  remainingAmount Decimal  @db.Decimal(12, 2)
  installments    LegacyDebtInstallment[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId])
}

model LegacyDebtInstallment {
  id            String      @id @default(uuid())
  debtId        String
  debt          LegacyDebt  @relation(fields: [debtId], references: [id], onDelete: Cascade)
  amount        Decimal     @db.Decimal(12, 2)
  dueDate       DateTime
  paidAt        DateTime?
  status        String      @default("ACTIVE") // ACTIVE, PAID
  transactionId String?     @unique // Powiązanie z transakcją po opłaceniu
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([debtId])
  @@index([status])
}


// Tabela N:M łącząca faktury z płatnościami (Append-Only Ledger).
// BRAK updatedAt – rekord jest niezmienialny po utworzeniu.
// Korekty wymagają nowej transakcji z type=REVERSAL.
model InvoicePayment {
  id            String      @id @default(uuid())
  invoiceId     String
  invoice       Invoice     @relation(fields: [invoiceId], references: [id])
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  amountApplied Decimal     @db.Decimal(12, 2)
  createdAt     DateTime    @default(now())

  @@index([invoiceId])
  @@index([transactionId])
  @@unique([invoiceId, transactionId])
}

model Transaction {
  id                    String                @id @default(uuid())
  tenantId              String
  tenant                Tenant                @relation(fields: [tenantId], references: [id])
  projectId             String?
  project               Project?              @relation(fields: [projectId], references: [id])
  amount                Decimal               @db.Decimal(12, 2)
  type                  String
  transactionDate       DateTime
  category              String
  description           String?
  status                String                @default("ACTIVE") // ACTIVE, REVERSED, DRAFT
  source                String                @default("MANUAL") // MANUAL, INVOICE, BANK_IMPORT
  externalId            String?               @unique
  bankTransactionId     String?               @unique // Link do wyciągu bankowego
  reversalOf            String?               // ID transakcji korygowanej
  scanUrl               String?               // OCR: Link do paragonu/dokumentu kosztowego
  invoicePayments       InvoicePayment[]      // N:M relacja – jedna transakcja może spłacać wiele faktur
  bankTransactions      BankTransactionRaw[]  @relation("PairedTransaction")
  classification          String                @default("PROJECT_COST") // PROJECT_COST, GENERAL_COST
  title                   String?
  counterpartyRaw         String?
  matchedContractorId   String?
  contractor            Contractor?           @relation(fields: [matchedContractorId], references: [id])
  tags                  String?               // Comma-separated tags
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  @@index([tenantId])
  @@index([tenantId, transactionDate])
  @@index([matchedContractorId])
}

model Liability {
  id                String   @id @default(uuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id])
  name              String
  totalAmount       Decimal  @db.Decimal(12, 2)
  installmentAmount Decimal  @db.Decimal(12, 2)
  startDate         DateTime
  endDate           DateTime
  paymentDayOfMonth Int
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([tenantId])
}

// ---------------------------------------------------------
// Bankowość Centralna (Open Banking)
// ---------------------------------------------------------
model BankAccount {
  id                 String               @id @default(uuid())
  tenantId           String
  tenant             Tenant               @relation(fields: [tenantId], references: [id])
  bankName           String
  iban               String               @unique
  currency           String               @default("PLN")
  providerAccountId  String?              // Zewnętrzny ID konta (np. z Plaid / Nordigen)
  rawTransactions    BankTransactionRaw[]
  isDefault          Boolean              @default(false)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  @@index([tenantId])
}

model BankTransactionRaw {
  id                  String       @id @default(uuid())
  tenantId            String
  tenant              Tenant       @relation(fields: [tenantId], references: [id])
  bankAccountId       String
  bankAccount         BankAccount  @relation(fields: [bankAccountId], references: [id])
  rawAmount           Decimal      @db.Decimal(12, 2)
  bookingDate         DateTime
  description         String
  senderName          String?
  status              String       @default("UNPAIRED")
  pairedTransactionId String?
  pairedTransaction   Transaction? @relation("PairedTransaction", fields: [pairedTransactionId], references: [id])
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  @@index([tenantId])
}

// ---------------------------------------------------------
// Bezpieczeństwo i Dziennik Zdarzeń
// ---------------------------------------------------------
model AuditLog {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String   // np. CREATE_INVOICE, UPDATE_PROJECT_STATUS
  entity    String   // np. Invoice, Project
  entityId  String
  details   Json?    // Przed/Po zmianie
  createdAt DateTime @default(now())

  @@index([tenantId])
}

model ProcessedEvent {
  id        String   @id @default(uuid())
  eventId   String   @unique
  source    String   // np. PKO_BP_CSV, WEBHOOK
  createdAt DateTime @default(now())
}

model Retention {
  id              String      @id @default(uuid())
  tenantId        String
  tenant          Tenant      @relation(fields: [tenantId], references: [id])
  projectId       String?
  project         Project?    @relation(fields: [projectId], references: [id])
  contractorId    String?
  contractor      Contractor? @relation(fields: [contractorId], references: [id])
  amount          Decimal     @db.Decimal(12, 2)
  type            String      // SHORT_TERM / LONG_TERM
  expiryDate      DateTime
  source          String      // PROJECT / MANUAL
  invoiceId       String?
  invoice         Invoice?    @relation(fields: [invoiceId], references: [id])
  description     String?
  status          String      @default("ACTIVE") // ACTIVE, DUE, RECOVERED
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([tenantId])
  @@index([projectId])
  @@index([expiryDate])
}

model Notification {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  type      String   // INFO, WARNING, SUCCESS, ERROR
  title     String
  message   String
  isRead    Boolean  @default(false)
  priority  String   @default("NORMAL") // LOW, NORMAL, HIGH
  link      String?  // Optional URL to navigate to
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  metadata  Json?    // For Diff or Actionable payloads

  @@index([tenantId])
}

enum KsefInvoiceStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum AssetSourceType {
  KSEF_LINKED
  MANUAL
}

enum AssetCategory {
  vehicle
  tool
  it
  equipment
}

enum AssetStatus {
  ACTIVE
  INACTIVE
  DAMAGED
  SOLD
}

enum SyncStatus {
  IN_SYNC
  MISSING_IN_FIRESTORE
  MISSING_IN_POSTGRES
  FIELD_MISMATCH
  SYNC_ERROR
  PENDING_RESYNC
}

enum SyncDirection {
  PG_TO_FS
  FS_TO_PG
  MANUAL_MERGE
}

model KsefInvoice {
  id              String             @id @default(uuid())
  tenantId        String
  tenant          Tenant             @relation(fields: [tenantId], references: [id])
  ksefNumber      String             @unique
  invoiceNumber   String             // P_2
  issueDate       DateTime           // P_1
  counterpartyNip String
  counterpartyName String
  netAmount       Decimal            @db.Decimal(12, 2)
  vatAmount       Decimal            @db.Decimal(12, 2)
  grossAmount     Decimal            @db.Decimal(12, 2)
  rawXml          String             @db.Text
  status          KsefInvoiceStatus  @default(PENDING)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([tenantId])
}

model BankStaging {
  id                String   @id @default(uuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id])
  date              DateTime
  amount            Decimal  @db.Decimal(12, 2)
  rawType           String   // Col 5: Opis operacji
  counterpartyName  String   // Col 6: Nazwa Nadawcy/Odbiorcy
  title             String?  // Col 8: Tytuł
  status            String   @default("PENDING") // PENDING, SUGGESTED, PROCESSED, IGNORED
  suggestionId      String?  // ID faktury sugerowanej (Invoice.id)
  matchConfidence   Float?   // Pewność dopasowania
  iban              String?
  processedAt       DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([tenantId])
  @@index([status])
}

enum LedgerSource {
  INVOICE
  BANK_PAYMENT
  SHADOW_COST
}

enum LedgerType {
  INCOME
  EXPENSE
  VAT_SHIELD
  RETENTION_LOCK
}

model LedgerEntry {
  id        String       @id @default(uuid())
  tenantId  String
  tenant    Tenant       @relation(fields: [tenantId], references: [id])
  projectId String?
  project   Project?     @relation(fields: [projectId], references: [id])
  source    LedgerSource
  sourceId  String       // ID faktury, transakcji bankowej lub kosztu shadow
  amount    Decimal      @db.Decimal(12, 2)
  type      LedgerType
  date      DateTime
  createdAt DateTime     @default(now())

  @@index([tenantId])
  @@index([projectId])
  @@index([sourceId])
  @@index([type])
  @@index([date])
}

model Asset {
  id               String   @id @default(uuid())
  tenantId         String
  tenant           Tenant   @relation(fields: [tenantId], references: [id])
  
  sourceType       AssetSourceType @default(MANUAL)
  sourceInvoiceId  String?
  invoice          Invoice?    @relation(fields: [sourceInvoiceId], references: [id])
  sourceDocumentNumber String?
  sourceDocumentDate   DateTime?

  name             String
  category         AssetCategory
  subcategory      String?
  brand            String?
  model            String?
  serialNumber     String?

  // vehicle-specific
  registrationNumber String?
  vin                String?
  insuranceEndDate   DateTime?
  inspectionDate     DateTime?
  mileage            Int?

  // operational ownership
  location           String?
  assignedTo         String?
  assignedProjectId  String?
  project            Project?    @relation(fields: [assignedProjectId], references: [id])

  // purchase / value
  purchaseDate     DateTime
  purchaseNet      Decimal  @db.Decimal(12, 2)
  purchaseGross    Decimal  @db.Decimal(12, 2)
  vatAmount        Decimal  @db.Decimal(12, 2)
  initialValue     Decimal  @db.Decimal(12, 2)
  currentValue     Decimal  @db.Decimal(12, 2)

  supplierId       String?
  contractor       Contractor? @relation(fields: [supplierId], references: [id])
  
  // lifecycle
  warrantyEndDate  DateTime?
  serviceDueDate   DateTime?
  status           AssetStatus   @default(ACTIVE)

  // future-ready depreciation fields
  depreciationMethod    String?  @default("LINEAR")
  depreciationRate      Decimal? @db.Decimal(5, 4)
  depreciationStartDate DateTime?
  monthlyDepreciation   Decimal? @db.Decimal(12, 2)

  notes            String?   @db.Text
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([tenantId])
  @@index([status])
  @@index([category])
  @@index([sourceInvoiceId])
}

enum DataDomain {
  FINANCIAL
  OPERATIONAL_ASSET
  KSEF_METADATA
  BANK_RECONCILIATION
  CONTRACTOR
  PROJECT
}

enum AuthoritySide {
  POSTGRES
  FIRESTORE
  EXTERNAL
}

model SyncAuditRecord {
  id              String   @id @default(uuid())
  entityType      String   // e.g., 'asset'
  entityId        String   
  domain          DataDomain    @default(FINANCIAL)
  authoritySide   AuthoritySide @default(POSTGRES)
  syncStatus      SyncStatus
  diffFields      Json?    // Array of { field, firestoreValue, postgresValue }
  lastCheckedAt   DateTime @default(now())
  lastSyncedAt    DateTime?
  lastSyncDirection SyncDirection?
  note            String?

  @@unique([entityType, entityId])
}
enum BankAccountSource {
  KSEF
  BANK_MATCH
  MANUAL
}

model ContractorBankAccount {
  id           String            @id @default(uuid())
  tenantId     String
  tenant       Tenant            @relation(fields: [tenantId], references: [id])
  contractorId String
  contractor   Contractor        @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  iban         String
  source       BankAccountSource @default(MANUAL)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@unique([tenantId, iban])
  @@index([tenantId])
  @@index([contractorId])
}

model IdentityConflictRecord {
  id                    String   @id @default(uuid())
  tenantId              String
  tenant                Tenant   @relation(fields: [tenantId], references: [id])
  iban                  String
  detectedContractorId  String
  existingContractorId  String
  details               String?  @db.Text
  createdAt             DateTime @default(now())

  @@index([tenantId])
  @@index([iban])
}
